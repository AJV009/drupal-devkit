# Canvas Migration Environment Configuration
# Copy this to .env and fill in your project-specific values

# Drupal CMS site URL (your DDEV site)
CANVAS_SITE_URL=https://your-project.ddev.site

# JSON:API endpoint prefix (default: jsonapi)
CANVAS_JSONAPI_PREFIX=jsonapi

# OAuth Client Credentials (create in Drupal admin: /admin/config/services/consumer)
CANVAS_CLIENT_ID=your-client-id
CANVAS_CLIENT_SECRET=your-client-secret

# Optional: OAuth scope override
# CONTENT_OAUTH_SCOPE=

# Optional: Disable OAuth (for development only)
# CONTENT_NO_AUTH=true
