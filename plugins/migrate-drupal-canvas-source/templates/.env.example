# Canvas Migration Environment Configuration (Acquia Source)
# Copy this to .env and fill in your project-specific values

# Acquia Source site URL
CANVAS_SITE_URL=https://your-site.acquia.com

# JSON:API endpoint prefix (default: api for Acquia Source)
CANVAS_JSONAPI_PREFIX=api

# OAuth Client Credentials (configured in Acquia Source admin)
CANVAS_CLIENT_ID=your-client-id
CANVAS_CLIENT_SECRET=your-client-secret

# Optional: OAuth scope override
# CONTENT_OAUTH_SCOPE=

# Optional: Disable OAuth (for development only)
# CONTENT_NO_AUTH=true
